# Anthropic — obrigatório
ANTHROPIC_API_KEY=sk-ant-...

# Tavily — obrigatório para busca na web (caps 2-12)
# Crie conta gratuita em tavily.com
TAVILY_API_KEY=tvly-...

# LangSmith — opcional, para observabilidade (cap 6)
# Crie conta gratuita em smith.langchain.com
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agente-mercado

# Groq — opcional, para fallback de modelo (cap 10)
# Crie conta gratuita em console.groq.com
GROQ_API_KEY=gsk_...

# API REST — chave de autenticação da API do cap11
API_KEY=troque-por-uma-chave-segura

# SMTP — opcional, para envio de e-mail de monitoramento (cap12)
# Sem configurar, o sistema imprime o relatório no console em vez de enviar
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
